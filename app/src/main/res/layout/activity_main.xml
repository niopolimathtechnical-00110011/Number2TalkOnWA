<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- Barra de Abas -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#075E54">

        <Button
            android:id="@+id/btn_aba1"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="📱 Conversa"
            android:textSize="12sp"
            android:background="@drawable/tab_selector"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_aba2"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="ℹ️ Sobre"
            android:textSize="12sp"
            android:background="@drawable/tab_selector"
            android:textColor="#FFFFFF" />

        <Button
            android:id="@+id/btn_aba3"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:text="⚙️ Debug"
            android:textSize="12sp"
            android:background="@drawable/tab_selector"
            android:textColor="#FFFFFF" />

    </LinearLayout>

    <!-- Conteúdo da Aba 1: Conversa -->
    <ScrollView
        android:id="@+id/aba1_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <ImageView
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/folder_apps"
                android:layout_gravity="center"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Number2Talk on WhatsApp"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#075E54"
                android:layout_gravity="center"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Copie um número de telefone e clique no balão flutuante para abrir diretamente no WhatsApp"
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btn_colar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📋 Colar número da área de transferência"
                android:textSize="16sp"
                android:backgroundTint="#075E54"
                android:textColor="#FFFFFF"
                android:padding="14dp" />

            <TextView
                android:id="@+id/txt_status"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✅ Status: Serviço em execução"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:gravity="center"
                android:padding="12dp"
                android:layout_marginTop="16dp"
                android:background="#E8F5E9" />

        </LinearLayout>
    </ScrollView>

    <!-- Conteúdo da Aba 2: Sobre e Doações -->
    <ScrollView
        android:id="@+id/aba2_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="👨‍💻 Desenvolvedor"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#075E54"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Enio Alves Borges"
                android:textSize="16sp"
                android:textColor="#333333"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐙 GitHub"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#075E54"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="https://github.com/niopolimathtechnical-00110011"
                android:textSize="14sp"
                android:textColor="#1976D2"
                android:autoLink="web"
                android:layout_marginBottom="24dp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DDDDDD"
                android:layout_marginVertical="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="☕ Doações"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#075E54"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Este app é útil para mim como está e fiz apenas como entusiasta, sem compromisso de upgrade ou correção de erros.. mas caso esteja funcional e seja útil para mais alguém, deixo ele para uso gratuito, embora, caso queira contribuir para esse e outros projetos, fico a disposição da aba Doações.."
                android:textSize="14sp"
                android:textColor="#666666"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btn_doacao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="☕ Fazer Doação (PIX)"
                android:textSize="16sp"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:padding="14dp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chave PIX: soletrepix@gmail.com"
                android:textSize="12sp"
                android:textColor="#1976D2"
                android:layout_gravity="center"
                android:layout_marginTop="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Titular: Enio Alves Borges | Banco do Brasil"
                android:textSize="12sp"
                android:textColor="#666666"
                android:layout_gravity="center"
                android:layout_marginTop="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🐠🐟 Sua contribuição ajuda a manter o projeto!"
                android:textSize="12sp"
                android:textColor="#4CAF50"
                android:layout_gravity="center"
                android:layout_marginTop="24dp" />

        </LinearLayout>
    </ScrollView>

    <!-- Conteúdo da Aba 3: Debug -->
    <LinearLayout
        android:id="@+id/aba3_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚙️ Debug - Relatório do Sistema"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#075E54"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btn_verificar_permissao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🔍 Verificar Permissão de Sobreposição"
            android:textSize="14sp"
            android:backgroundTint="#9C27B0"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_testar_clipboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📋 Testar Leitura do Clipboard"
            android:textSize="14sp"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_enviar_log"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📤 Enviar Log Completo para WhatsApp"
            android:textSize="14sp"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📝 Logs do Sistema:"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#333333"
            android:layout_marginBottom="8dp" />

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#F0F0F0"
            android:padding="8dp">

            <TextView
                android:id="@+id/txt_logs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Aguardando eventos..."
                android:textSize="11sp"
                android:textColor="#333333"
                android:fontFamily="monospace" />

        </ScrollView>

    </LinearLayout>

</LinearLayout>
