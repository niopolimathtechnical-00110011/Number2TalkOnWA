<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="⚙️ Debug - Status do Serviço"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#075E54"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:id="@+id/txt_debug_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Verificando..."
        android:textSize="14sp"
        android:textColor="#333333"
        android:padding="12dp"
        android:background="#E0E0E0"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_verificar_permissao"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🔍 Verificar Permissão de Sobreposição"
        android:textSize="14sp"
        android:backgroundTint="#FF9800"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btn_testar_clipboard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Testar Leitura do Clipboard"
        android:textSize="14sp"
        android:backgroundTint="#2196F3"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="16dp"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <TextView
            android:id="@+id/txt_logs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Logs do sistema aparecerão aqui..."
            android:textSize="12sp"
            android:textColor="#666666"
            android:fontFamily="monospace"
            android:padding="8dp"
            android:background="#F0F0F0"/>

    </ScrollView>

</LinearLayout>
