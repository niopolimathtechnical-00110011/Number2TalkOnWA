<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="24dp">

    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@drawable/folder_apps"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Number2Talk on WhatsApp"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Copie um número e clique no balão flutuante"
        android:textSize="14sp"
        android:textColor="#666666"
        android:layout_marginBottom="32dp"
        android:gravity="center"/>

    <Button
        android:id="@+id/btn_colar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 Colar número da área de transferência"
        android:textSize="16sp"
        android:backgroundTint="#075E54"
        android:textColor="#FFFFFF"
        android:padding="14dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: ✅ Serviço ativo"
        android:id="@+id/txt_status"
        android:textSize="12sp"
        android:textColor="#4CAF50"
        android:layout_marginTop="24dp"/>

</LinearLayout>
